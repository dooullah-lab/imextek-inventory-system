# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to GitHub.

PORT=5000

# AWS credentials - use a scoped IAM user with DynamoDB-only permissions
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB table names (must match what you create in AWS console)
USERS_TABLE=ImExTek_Users
PRODUCTS_TABLE=ImExTek_Products
TRANSACTIONS_TABLE=ImExTek_Transactions

# JWT secret - use a long random string (we'll generate one together)
JWT_SECRET=replace_this_with_a_long_random_string
